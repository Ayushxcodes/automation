// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {

  id String @id @default(cuid())

  email String @unique
  password String

  createdAt DateTime @default(now())

  integrations Integration[]

  automations Automation[]

  projects Project[]

  assignedTasks Task[]

  role String @default("user") 
  
  activityLogs ActivityLog[]

  emails Email[]
}

model Integration {

  id String @id @default(cuid())

  type String
  accessToken String?

  userId String
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

}

model Automation {

  id String @id @default(cuid())

  trigger String
  actions String[]

  userId String
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  logs AutomationLog[]

}

model AutomationLog {

  id String @id @default(cuid())

  output String

  automationId String
  automation Automation @relation(fields: [automationId], references: [id])

  createdAt DateTime @default(now())

}

model Email {

  id String @id @default(cuid())

  content String

  userId String
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

}

model Project {
  id String @id @default(cuid())

  name String

  userId String
  user User @relation(fields: [userId], references: [id])

  tasks Task[]

  createdAt DateTime @default(now())
}

model Task {

  id String @id @default(cuid())

  title String
  description String?

  status String @default("todo")

  // Content metadata
  format      String?   // reel | post | thread | video
  platform    String?   // yt | ig | li | tw
  topic       String?   // personal brand | ai | etc
  publishDate DateTime?

  // Metrics
  ytViews        Int? @default(0)
  igReach        Int? @default(0)
  liImpressions  Int? @default(0)
  twImpressions  Int? @default(0)

  projectId String
  project Project @relation(fields: [projectId], references: [id])

  assignedToId String?
  assignedTo User? @relation(fields: [assignedToId], references: [id])

  logs  ActivityLog[]
  briefs Brief[]        // 🔥 opposite relation for Brief.task

  createdAt DateTime @default(now())
}

model ActivityLog {

  id String @id @default(cuid())

  action String
  details String?

  userId String
  user User @relation(fields: [userId], references: [id])

  taskId String?
  task Task? @relation(fields: [taskId], references: [id])

  createdAt DateTime @default(now())
}

model Brief {

  id String @id @default(cuid())

  taskId String @unique
  task Task @relation(fields: [taskId], references: [id])

  hook String?
  angle String?
  message String?
  visuals String?
  script String?

  createdAt DateTime @default(now())
}

model Chat {
  id        String   @id @default(cuid())
  title     String?
  userId    String
  messages  Message[]
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
}